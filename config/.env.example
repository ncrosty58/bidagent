# BidAgent Configuration
# Copy to .env and fill in your values

PORT=8000
HOST_PORT=8000

# LLM (OpenAI-compatible API — works with Gemini, OpenAI, etc.)
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_API_KEY=your_api_key_here
LLM_MODEL_NAME=gemini-2.5-flash

# Twenty CRM (for live pricing)
TWENTY_CRM_API_URL=
TWENTY_CRM_BEARER_TOKEN=

# Active skill profile (must match a .yaml file in skills/)
ACTIVE_SKILL=curbclass
